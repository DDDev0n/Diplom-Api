POSTGRES_DB=bank_processing
POSTGRES_USER=bank_user
POSTGRES_PASSWORD=bank_password
DATABASE_URL=postgres://bank_user:bank_password@postgres:5432/bank_processing?sslmode=disable

REDIS_URL=redis://redis:6379/0
RABBITMQ_DEFAULT_USER=bank_user
RABBITMQ_DEFAULT_PASS=bank_password
RABBITMQ_URL=amqp://bank_user:bank_password@rabbitmq:5672/

JWT_SECRET=change-me-in-production-32-chars-min
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

PROCESSING_SERVICE_URL=https://pay.projectl.ru
PROCESSING_LOGIN_PATH=/api/v1/auth/login
PROCESSING_PROCESS_PATH=/api/v1/payments/process
PROCESSING_AUTH_TOKEN=
PROCESSING_AUTH_USERNAME=tester
PROCESSING_AUTH_ROLE=USER
PROCESSING_INSECURE_SKIP_VERIFY=false
PAYMENT_REVIEW_THRESHOLD=100000
